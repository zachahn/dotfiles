// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      "cmd-t": "terminal_panel::ToggleFocus",
      "ctrl-p": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "f12": "editor::GoToDefinition",
      "ctrl-p": "file_finder::Toggle",
      "cmd-t": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "ctrl-e": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }]
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-shift-g": "vim::ShowLocation",
      "alt-cmd-c": "editor::CopyRelativePath",
      "ctrl-g": ["workspace::SendKeystrokes", "ctrl-shift-g alt-cmd-c"],
      "_": "tab_switcher::ToggleAll",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "= p": ["workspace::SendKeystrokes", "p"],
      "space l": ["workspace::SendKeystrokes", "cmd-f escape"]
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space y": ["workspace::SendKeystrokes", "cmd-c escape"]
    }
  },
  {
    "context": "!ContextEditor > (Editor && mode == full) && vim_mode == normal",
    "bindings": {
      "-": "pane::RevealInProjectPanel"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal"
    }
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "escape": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "(VimControl || (!Editor))",
    "bindings": {
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": ["workspace::SendKeystrokes", "ctrl-~"]
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-k up": null
    }
